<section class="section product-detail">
  <div class="container product-detail-grid product-detail-container">
    <div class="product-media" data-product-media>
      {% if product.featured_image %}
        {% assign zoom_url = product.featured_image | image_url: width: 2000 %}
        <div class="product-media-main" data-media-main>
          {{ product.featured_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: product.title, data_media_img: true, data_media_zoom: zoom_url }}
          <div class="product-zoom-lens" data-zoom-lens></div>
          <div class="product-zoom-window" data-zoom-window></div>
        </div>
      {% endif %}
      {% if product.images.size > 1 %}
        <div class="product-media-strip" role="list">
          {% for image in product.images %}
            {% assign thumb_zoom = image | image_url: width: 2000 %}
            <button
              class="product-media-thumb{% if image.id == product.featured_image.id %} is-active{% endif %}"
              type="button"
              data-media-thumb
              data-media-src="{{ image | image_url: width: 1200 }}"
              data-media-zoom="{{ thumb_zoom }}"
              aria-label="View {{ product.title }} image {{ forloop.index }}"
              role="listitem"
            >
              {{ image | image_url: width: 200 | image_tag: loading: 'lazy', alt: product.title }}
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>
    <div class="product-zoom-modal" data-zoom-modal>
      <button class="product-zoom-close" type="button" aria-label="Close zoom">×</button>
      <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title }}">
    </div>
    <div class="product-info">
      <h1 class="hero-title">{{ product.title }}</h1>
      <p>{{ product.description | strip_html }}</p>
      <div class="price">{{ product.price | money }}</div>
      <form method="post" action="/cart/add" data-add-to-cart data-variant-id="{{ product.selected_or_first_available_variant.id }}">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <div class="product-cart-actions" data-product-cart-actions>
          <button class="button button-primary" type="submit" data-add-to-cart-button>Add to cart</button>
          <div class="product-qty-controls" data-product-qty-controls hidden>
            <button class="product-qty-btn" type="button" data-product-qty-btn="minus" aria-label="Decrease quantity">-</button>
            <span class="product-qty-count" data-product-qty-count>0 in cart</span>
            <button class="product-qty-btn" type="button" data-product-qty-btn="plus" aria-label="Increase quantity">+</button>
          </div>
        </div>
      </form>
      {% assign upsell_product = all_products['adhesive-wall-strip'] %}
      {% if upsell_product != blank and product.handle != upsell_product.handle %}
        <div class="product-upsell-inline">
          <div class="upsell-card">
            <div>
              <span class="upsell-eyebrow">Recommended add-on</span>
              <h3 class="upsell-title">
                <a class="upsell-link" href="{{ upsell_product.url }}">Add adhesive strips to your order</a>
              </h3>
              <p class="upsell-subtitle">Attach your rug to your wall!</p>
            </div>
            <form class="upsell-quick-add" method="post" action="/cart/add" data-upsell-quick-add>
              <input type="hidden" name="id" value="{{ upsell_product.selected_or_first_available_variant.id }}">
              <button class="button button-secondary" type="submit">Add to cart</button>
            </form>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<section class="section product-media-full">
  {% if section.settings.media_video != blank %}
    {{ section.settings.media_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
  {% elsif section.settings.media_image != blank %}
    {{ section.settings.media_image | image_url: width: 2400 | image_tag: loading: 'lazy', alt: product.title }}
  {% endif %}
</section>

<section class="section product-related">
  <div class="container">
    <div class="globo_widget_26011"></div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": [
    {"type": "video", "id": "media_video", "label": "Product media video"},
    {"type": "image_picker", "id": "media_image", "label": "Product media image"}
  ]
}
{% endschema %}
