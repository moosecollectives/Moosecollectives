<section class="section">
  <div class="container hero">

    <div class="product-gallery">
      {% assign images = product.images %}
      {% if images.size > 0 %}
        <div class="gallery-main">
          {{ images[0] | image_url: width: 1200 | image_tag: loading: 'eager', alt: product.title, class: 'gallery-main-img', id: 'gallery-main-img', width: images[0].width, height: images[0].height }}
        </div>
        {% if images.size > 1 %}
          <div class="gallery-thumbs">
            {% for image in images %}
              <button class="gallery-thumb {% if forloop.first %}active{% endif %}"
                data-src="{{ image | image_url: width: 1200 }}"
                aria-label="{{ product.title }} — image {{ forloop.index }}">
                {{ image | image_url: width: 160 | image_tag: loading: 'lazy', alt: product.title, width: image.width, height: image.height }}
              </button>
            {% endfor %}
          </div>
        {% endif %}
      {% endif %}
    </div>

    <div class="hero-card">
      <h1 class="hero-title">{{ product.title }}</h1>

      <div class="product-price">
        {% if product.compare_at_price > product.price %}
          <span class="price price-sale">{{ product.price | money }}</span>
          <span class="price price-compare">{{ product.compare_at_price | money }}</span>
          <span class="badge-sale">Sale</span>
        {% else %}
          <span class="price">{{ product.price | money }}</span>
        {% endif %}
      </div>

      {% assign active_variant = product.selected_or_first_available_variant %}
      {% if product.available %}
        {% if active_variant.inventory_management == 'shopify' and active_variant.inventory_quantity > 0 and active_variant.inventory_quantity <= 5 %}
          <p class="stock-indicator low-stock">&#9889; Only {{ active_variant.inventory_quantity }} left — order soon</p>
        {% endif %}
      {% endif %}

      <div class="product-description">{{ product.description }}</div>

      {% unless product.has_only_default_variant %}
        {% for option in product.options_with_values %}
          <div class="product-option">
            <label class="option-label">{{ option.name }}</label>
            <div class="option-values">
              {% for value in option.values %}
                <button class="option-btn {% if option.selected_value == value %}active{% endif %}"
                  data-option-index="{{ forloop.parentloop.index0 }}"
                  data-value="{{ value }}">{{ value }}</button>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      {% endunless %}

      {% if product.available %}
        <form id="product-form" data-product-id="{{ product.id }}">
          <input type="hidden" name="id" id="variant-id" value="{{ active_variant.id }}">
          <button class="button button-primary btn-add-to-cart" type="submit">Add to cart</button>
        </form>
      {% else %}
        <button class="button button-primary btn-add-to-cart" disabled>Sold out</button>
        <div class="back-in-stock">
          <p class="bis-heading">Get notified when back in stock</p>
          <form class="bis-form" action="/contact#contact_form" method="post">
            <input type="hidden" name="form_type" value="contact">
            <input type="hidden" name="utf8" value="✓">
            <input type="hidden" name="contact[body]" value="Back in stock request: {{ product.title }}">
            <input type="hidden" name="contact[subject]" value="Restock request: {{ product.title }}">
            <label for="bis-email" class="input-label">Your email</label>
            <div class="newsletter-row">
              <input id="bis-email" class="email-input" type="email" name="contact[email]" placeholder="your@email.com" required autocomplete="email">
              <button class="button button-primary" type="submit">Notify me</button>
            </div>
          </form>
          <p class="bis-legal">We'll email you the moment it's available.</p>
        </div>
      {% endif %}
    </div>

  </div>
</section>

{% assign first_col = product.collections | first %}
{% if first_col and first_col.products_count > 1 %}
  <section class="section related-section">
    <div class="container">
      <div class="section-heading">
        <h2 class="section-title">You might also like</h2>
      </div>
      <div class="product-grid">
        {% assign related_shown = 0 %}
        {% for rp in first_col.products %}
          {% unless rp.id == product.id or related_shown >= 4 %}
            <article class="product-card">
              <a href="{{ rp.url }}">
                <div class="product-card-img">
                  {% if rp.featured_image %}
                    {{ rp.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: rp.title, width: rp.featured_image.width, height: rp.featured_image.height }}
                  {% endif %}
                  {% unless rp.available %}<span class="card-badge badge-out">Sold out</span>{% endunless %}
                </div>
                <h3>{{ rp.title }}</h3>
                <span class="price">{{ rp.price | money }}</span>
              </a>
            </article>
            {% assign related_shown = related_shown | plus: 1 %}
          {% endunless %}
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}

<script>window.productVariants = {{ product.variants | json }};</script>

{% schema %}
{
  "name": "Main product",
  "settings": []
}
{% endschema %}
