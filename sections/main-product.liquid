<section class="section product-detail">
  <div class="container product-detail-grid">
    <div class="product-media">
      {% if product.featured_image %}
        {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: product.title }}
      {% endif %}
      <div class="product-media-video">
        {% if section.settings.media_video != blank %}
          {{ section.settings.media_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
        {% else %}
          <div class="product-media-placeholder">Add product video</div>
        {% endif %}
      </div>
      {% assign adhesive_product = all_products['adhesive-wall-strip'] %}
      <div class="product-strip">
        <span>No room on your floor? Take your rug to the walls.</span>
        {% if adhesive_product != blank %}
          <div class="product-strip-offer">
            <strong>{{ adhesive_product.title }}</strong>
            <span class="price">{{ adhesive_product.price | money }}</span>
            {% if adhesive_product.available %}
              <form method="post" action="{{ routes.cart_add_url }}">
                <input type="hidden" name="id" value="{{ adhesive_product.selected_or_first_available_variant.id }}">
                <input type="hidden" name="quantity" value="1">
                <button class="button button-secondary" type="submit">Add to cart</button>
              </form>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
    <div class="product-info">
      <h1 class="hero-title">{{ product.title }}</h1>
      <p>{{ product.description | strip_html }}</p>
      <div class="price">{{ product.price | money }}</div>
      <form method="post" action="/cart/add">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <button class="button button-primary" type="submit">Add to cart</button>
      </form>
    </div>
  </div>
</section>

<section class="section product-feature-block">
  <div class="container feature-placeholder">
    <h2 class="section-title">Featured drop</h2>
    <p>Add your featured content here soon.</p>
  </div>
</section>

<section class="section product-media-block">
  <div class="container media-placeholder">
    <p>Add an image or video here later.</p>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": [
    {"type": "video", "id": "media_video", "label": "Product media video"}
  ]
}
{% endschema %}
