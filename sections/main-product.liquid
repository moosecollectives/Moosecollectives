<section class="section product-detail">
  <div class="container product-detail-grid">
    <a class="product-back" href="{{ routes.all_products_collection_url }}" aria-label="Back to products">
      <span aria-hidden="true">‹</span>
    </a>
    <div class="product-media">
      {% if product.featured_image %}
        {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: product.title }}
      {% endif %}
    </div>
    <div class="product-info">
      <h1 class="hero-title">{{ product.title }}</h1>
      <p>{{ product.description | strip_html }}</p>
      <div class="price">{{ product.price | money }}</div>
      <form method="post" action="/cart/add" data-add-to-cart data-variant-id="{{ product.selected_or_first_available_variant.id }}">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <div class="product-cart-actions" data-product-cart-actions>
          <button class="button button-primary" type="submit" data-add-to-cart-button>Add to cart</button>
          <div class="product-qty-controls" data-product-qty-controls hidden>
            <button class="product-qty-btn" type="button" data-product-qty-btn="minus" aria-label="Decrease quantity">-</button>
            <span class="product-qty-count" data-product-qty-count>0 in cart</span>
            <button class="product-qty-btn" type="button" data-product-qty-btn="plus" aria-label="Increase quantity">+</button>
          </div>
        </div>
      </form>
      {% assign upsell_product = all_products['adhesive-wall-strip'] %}
      {% if upsell_product != blank and product.handle != upsell_product.handle %}
        <div class="product-upsell-inline">
          <div class="upsell-card">
            <div>
              <span class="upsell-eyebrow">Recommended add-on</span>
              <h3 class="upsell-title">Add adhesive strips to your order</h3>
              <p class="upsell-subtitle">Keep your rug secure with our mounting strips.</p>
            </div>
            <a class="button button-secondary" href="{{ upsell_product.url }}">View adhesive strips</a>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<section class="section product-related">
  <div class="container">
    <div class="globo_widget_26011"></div>
  </div>
</section>

<section class="section product-feature-block">
  <div class="container feature-placeholder">
    <h2 class="section-title">Featured drop</h2>
    <p>Add your featured content here soon.</p>
  </div>
</section>

<section class="section product-media-block">
  <div class="container media-placeholder">
    <p>Add an image or video here later.</p>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": []
}
{% endschema %}
