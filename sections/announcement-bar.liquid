{% if section.settings.message_1 != blank %}
  <div class="announce-bar" role="status">
    <span>{{ section.settings.message_1 }}</span>
    {% if section.settings.message_2 != blank %}
      <span class="announce-dot announce-hide-mobile" aria-hidden="true">·</span>
      <span class="announce-hide-mobile">{{ section.settings.message_2 }}</span>
    {% endif %}
  </div>
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {"type": "text", "id": "message_1", "label": "Message", "default": "30% off sitewide — no code needed"},
    {"type": "text", "id": "message_2", "label": "Second message (desktop only)", "default": "Limited runs — gone when they're gone"}
  ]
}
{% endschema %}
