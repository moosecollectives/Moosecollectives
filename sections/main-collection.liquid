<section class="section">
  <div class="container">
    <div class="section-heading collection-heading">
      <h1 class="section-title">Full collection</h1>
      <div class="collection-heading-meta">
        <span>{{ collection.products_count }} items</span>
        {% assign current_sort = collection.sort_by %}
        <form class="collection-sort" method="get" action="{{ collection.url }}">
          <label for="CollectionSort">Sort</label>
          <select id="CollectionSort" name="sort_by" onchange="this.form.submit()">
            <option value=""{% if current_sort == blank %} selected{% endif %} hidden>General</option>
            <option value="price-ascending"{% if current_sort == 'price-ascending' %} selected{% endif %}>Price: Low to High</option>
            <option value="price-descending"{% if current_sort == 'price-descending' %} selected{% endif %}>Price: High to Low</option>
          </select>
        </form>
      </div>
    </div>
    {% assign adhesive_handle = 'adhesive-wall-strip' %}
    {% assign adhesive_product = all_products[adhesive_handle] %}
    <div class="collection-grid">
      {% for product in collection.products %}
        {% if product.handle == adhesive_handle %}
          {% continue %}
        {% endif %}
        <article class="product-carousel-card collection-carousel-card">
          <a href="{{ product.url }}">
            {% if product.featured_image %}
              {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: product.title }}
            {% endif %}
            <h3>{{ product.title }}</h3>
            {% assign compare_price = product.price | times: 100 | divided_by: 85 %}
            {% assign compare_price = compare_price | plus: 99 | divided_by: 100 | times: 100 %}
            <span class="price price-current">{{ product.price | money }}</span>
            <span class="price-compare">{{ compare_price | money }}</span>
          </a>
        </article>
      {% endfor %}
    </div>
    {% if adhesive_product != blank %}
      <div class="collection-adhesive">
        <div class="collection-adhesive-card">
          <div>
            <h2>{{ adhesive_product.title }}</h2>
            <p class="collection-adhesive-copy">Keep your rug attached to the wall with these mounting strips.</p>
            <span class="price">{{ adhesive_product.price | money }}</span>
          </div>
          <a class="button button-primary" href="{{ adhesive_product.url }}">View adhesive wall strip</a>
        </div>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main collection",
  "settings": []
}
{% endschema %}
