<section class="section">
  <div class="container">
    <div class="section-heading">
      <h1 class="section-title">{{ collection.title }}</h1>
      <span>{{ collection.products_count }} items</span>
    </div>
    <div class="product-grid">
      {% for product in collection.products %}
        <article class="product-card">
          <a href="{{ product.url }}">
            {% if product.featured_image %}
              {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title, width: product.featured_image.width, height: product.featured_image.height }}
            {% endif %}
            <h3>{{ product.title }}</h3>
            <span class="price">{{ product.price | money }}</span>
          </a>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main collection",
  "settings": []
}
{% endschema %}
