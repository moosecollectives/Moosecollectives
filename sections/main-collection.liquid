<section class="section">
  <div class="container">
    <div class="section-heading collection-heading">
      <h1 class="section-title">Full collection</h1>
      <span>{{ collection.products_count }} items</span>
    </div>
    <div class="collection-grid">
      {% for product in collection.products %}
        <article class="product-carousel-card collection-carousel-card">
          <a href="{{ product.url }}">
            {% if product.featured_image %}
              {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: product.title }}
            {% endif %}
            <h3>{{ product.title }}</h3>
            <span class="price">{{ product.price | money }}</span>
          </a>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main collection",
  "settings": []
}
{% endschema %}
