{% assign carousel_collection = section.settings.collection %}
{% if carousel_collection == blank %}
  {% assign carousel_collection = collections['all'] %}
{% endif %}

<section class="section carousel-section carousel-section-fancy">
  {% if section.settings.heading != blank or section.settings.cta_label != blank %}
    <div class="container">
      <div class="section-heading{% if section.settings.heading == blank %} section-heading-center{% endif %}">
        {% if section.settings.heading != blank %}
          <h2 class="section-title">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if carousel_collection != blank and section.settings.cta_label != blank %}
          <a class="button button-primary" href="{{ carousel_collection.url }}">
            {{ section.settings.cta_label }}
          </a>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {% if carousel_collection != blank and carousel_collection.products_count > 0 %}
    <div class="product-carousel" data-carousel data-direction="{{ section.settings.direction }}" data-start="{% if section.settings.start_from_end %}end{% else %}start{% endif %}" data-speed="{{ section.settings.speed }}">
      <div class="product-carousel-track" data-carousel-track>
        {% for product in carousel_collection.products limit: section.settings.max_products %}
          {% if product.handle == 'adhesive-wall-strip' %}
            {% continue %}
          {% endif %}
          <article class="product-carousel-card" data-carousel-card>
            {% if product.available %}
              <span class="card-badge" aria-hidden="true">Limited run</span>
            {% endif %}
            <a href="{{ product.url }}">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 700 | image_tag: loading: 'lazy', alt: product.title }}
              {% endif %}
              <h3>{{ product.title }}</h3>
              {% assign compare_price = product.price | times: 100 | divided_by: 85 %}
              {% assign compare_price = compare_price | plus: 99 | divided_by: 100 | times: 100 %}
              <span class="price price-current">{{ product.price | money }}</span>
              <span class="price-compare">{{ compare_price | money }}</span>
            </a>
            {% if product.available %}
              <form class="card-quick-add" method="post" action="/cart/add" data-add-to-cart data-variant-id="{{ product.selected_or_first_available_variant.id }}">
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                <button class="button button-primary" type="submit" data-add-to-cart-button>Add to cart</button>
              </form>
            {% endif %}
          </article>
        {% endfor %}
        {% for product in carousel_collection.products limit: section.settings.max_products %}
          {% if product.handle == 'adhesive-wall-strip' %}
            {% continue %}
          {% endif %}
          <article class="product-carousel-card" data-carousel-card>
            {% if product.available %}
              <span class="card-badge" aria-hidden="true">Limited run</span>
            {% endif %}
            <a href="{{ product.url }}">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 700 | image_tag: loading: 'lazy', alt: product.title }}
              {% endif %}
              <h3>{{ product.title }}</h3>
              {% assign compare_price = product.price | times: 100 | divided_by: 85 %}
              {% assign compare_price = compare_price | plus: 99 | divided_by: 100 | times: 100 %}
              <span class="price price-current">{{ product.price | money }}</span>
              <span class="price-compare">{{ compare_price | money }}</span>
            </a>
            {% if product.available %}
              <form class="card-quick-add" method="post" action="/cart/add" data-add-to-cart data-variant-id="{{ product.selected_or_first_available_variant.id }}">
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                <button class="button button-primary" type="submit" data-add-to-cart-button>Add to cart</button>
              </form>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    </div>
  {% else %}
    <div class="container">
      <p>No products available to display.</p>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Product carousel",
  "settings": [
    {"type": "text", "id": "heading", "label": "Heading", "default": "All products"},
    {"type": "collection", "id": "collection", "label": "Collection (defaults to All products)"},
    {"type": "text", "id": "cta_label", "label": "CTA label", "default": "Browse collection"},
    {
      "type": "select",
      "id": "direction",
      "label": "Scroll direction",
      "options": [
        {"value": "left", "label": "Left"},
        {"value": "right", "label": "Right"}
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "start_from_end",
      "label": "Start from end of list",
      "default": false
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products",
      "min": 4,
      "max": 50,
      "step": 2,
      "default": 50
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed",
      "min": 0.2,
      "max": 1.2,
      "step": 0.1,
      "default": 0.4
    }
  ],
  "presets": [{"name": "Product carousel"}]
}
{% endschema %}
