{% assign carousel_collection = section.settings.collection %}
{% if carousel_collection == blank %}
  {% assign carousel_collection = collections['all'] %}
{% endif %}

<section class="section carousel-section">
  {% if section.settings.heading != blank or section.settings.cta_label != blank %}
    <div class="container">
      <div class="section-heading{% if section.settings.heading == blank %} section-heading-center{% endif %}">
        {% if section.settings.heading != blank %}
          <h2 class="section-title">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if carousel_collection != blank and section.settings.cta_label != blank %}
          <a class="button button-primary" href="{{ carousel_collection.url }}">
            {{ section.settings.cta_label }}
          </a>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {% if carousel_collection != blank and carousel_collection.products_count > 0 %}
    <div class="container">
      <div class="case-opening" data-case-carousel>
        <audio data-case-audio src="{{ 'case-opening.mp3' | asset_url }}" preload="auto"></audio>
        <div class="case-viewport">
          <div class="case-center-line" aria-hidden="true"></div>
          <div class="case-track" data-case-track>
            {% for product in carousel_collection.products limit: section.settings.max_products %}
              <article
                class="case-item"
                data-case-item
                data-title="{{ product.title | escape }}"
                data-url="{{ product.url }}"
                data-image="{{ product.featured_image | image_url: width: 900 }}"
                data-description="{{ product.description | strip_html | truncate: 140 | escape }}"
                data-variant="{{ product.selected_or_first_available_variant.id }}"
                data-price="{{ product.price | money }}"
              >
                {% if product.featured_image %}
                  {{ product.featured_image | image_url: width: 500 | image_tag: loading: 'lazy', alt: product.title }}
                {% endif %}
                <span class="case-item-title">{{ product.title }}</span>
              </article>
            {% endfor %}
            {% for product in carousel_collection.products limit: section.settings.max_products %}
              <article
                class="case-item"
                data-case-item
                data-title="{{ product.title | escape }}"
                data-url="{{ product.url }}"
                data-image="{{ product.featured_image | image_url: width: 900 }}"
                data-description="{{ product.description | strip_html | truncate: 140 | escape }}"
                data-variant="{{ product.selected_or_first_available_variant.id }}"
                data-price="{{ product.price | money }}"
              >
                {% if product.featured_image %}
                  {{ product.featured_image | image_url: width: 500 | image_tag: loading: 'lazy', alt: product.title }}
                {% endif %}
                <span class="case-item-title">{{ product.title }}</span>
              </article>
            {% endfor %}
          </div>
        </div>
        <div class="case-actions">
          <button class="button button-primary case-overlay-button" type="button" data-case-spin>Open rugs</button>
        </div>
      </div>
    </div>
    <div class="case-result" data-case-result hidden>
      <div class="case-result-card">
        <button class="case-result-close" type="button" aria-label="Close result">×</button>
        <img data-case-result-image alt="">
        <h3 data-case-result-title></h3>
        <p data-case-result-description></p>
        <div class="case-result-footer">
          <span class="case-result-price" data-case-result-price></span>
          <span class="sale-pill">Spring Opening Sale · 15% off</span>
          <form method="post" action="/cart/add" data-case-result-add>
            <input type="hidden" name="id" data-case-result-variant>
            <button class="button button-primary" type="submit">Add to cart</button>
          </form>
        </div>
      </div>
    </div>
  {% else %}
    <div class="container">
      <p>No products available to display.</p>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Product carousel",
  "settings": [
    {"type": "text", "id": "heading", "label": "Heading", "default": "All products"},
    {"type": "collection", "id": "collection", "label": "Collection (defaults to All products)"},
    {"type": "text", "id": "cta_label", "label": "CTA label", "default": "Browse collection"},
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products",
      "min": 4,
      "max": 50,
      "step": 2,
      "default": 50
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed",
      "min": 0.2,
      "max": 1.2,
      "step": 0.1,
      "default": 0.4
    }
  ],
  "presets": [{"name": "Product carousel"}]
}
{% endschema %}
