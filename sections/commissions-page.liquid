<!-- Commissions page hero -->
<section class="comm-hero">
  <div class="container comm-hero-inner">
    <span class="comm-eyebrow">Custom work</span>
    <h1 class="comm-heading">Your vision,<br>tufted to life.</h1>
    <p class="comm-subheading">We take on a limited number of custom commissions each month. Every piece is made to order — your character, your size, your wall.</p>
  </div>
</section>

<!-- How it works -->
<section class="section comm-process-section">
  <div class="container">
    <div class="comm-process-grid">

      <div class="comm-step">
        <span class="comm-step-num">01</span>
        <h3 class="comm-step-title">Submit your idea</h3>
        <p class="comm-step-copy">Fill out the form below with your character, dimensions, and any reference images. The more detail, the better.</p>
      </div>

      <div class="comm-step">
        <span class="comm-step-num">02</span>
        <h3 class="comm-step-title">We review & quote</h3>
        <p class="comm-step-copy">We'll get back to you within 2–3 business days with a price and estimated timeline. No obligation to proceed.</p>
      </div>

      <div class="comm-step">
        <span class="comm-step-num">03</span>
        <h3 class="comm-step-title">Approve & receive</h3>
        <p class="comm-step-copy">Once you approve the design mockup and deposit, we tuft your piece and ship it straight to you.</p>
      </div>

    </div>
  </div>
</section>

<!-- Details bar -->
<div class="comm-details-bar">
  <div class="container comm-details-inner">
    <div class="comm-detail">
      <span class="comm-detail-label">Turnaround</span>
      <span class="comm-detail-value">3–6 weeks</span>
    </div>
    <div class="comm-detail-divider" aria-hidden="true"></div>
    <div class="comm-detail">
      <span class="comm-detail-label">Sizes</span>
      <span class="comm-detail-value">Any size, any shape</span>
    </div>
    <div class="comm-detail-divider" aria-hidden="true"></div>
    <div class="comm-detail">
      <span class="comm-detail-label">Characters</span>
      <span class="comm-detail-value">Anime, games, movies & more</span>
    </div>
    <div class="comm-detail-divider" aria-hidden="true"></div>
    <div class="comm-detail">
      <span class="comm-detail-label">Deposit</span>
      <span class="comm-detail-value">50% upfront</span>
    </div>
  </div>
</div>

<!-- Commission request form -->
<section class="section comm-form-section">
  <div class="container comm-form-inner">
    <div class="comm-form-header">
      <h2 class="comm-form-title">Start your commission</h2>
      <p class="comm-form-subtitle">Spots are limited each month. Fill out the form and we'll reach out to get things started.</p>
    </div>
    <div class="comm-form-widget">
      {{ page.content }}
      <div class="globo_widget_26011"></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Commissions page",
  "settings": []
}
{% endschema %}
