<section class="brand-manifesto-section">
  <div class="container">
    <div class="manifesto-grid">

      <div class="manifesto-card">
        <span class="manifesto-num">01</span>
        <div class="manifesto-body">
          <h3 class="manifesto-heading">Limited run,<br>always.</h3>
          <p class="manifesto-copy">Every piece drops in a limited quantity and never restocks. When it's gone, it's gone — that's what makes it worth hanging.</p>
        </div>
      </div>

      <div class="manifesto-card">
        <span class="manifesto-num">02</span>
        <div class="manifesto-body">
          <h3 class="manifesto-heading">Pop culture,<br>reframed.</h3>
          <p class="manifesto-copy">Characters and worlds you actually love — not generic wall filler. Every design is chosen because it means something to real collectors.</p>
        </div>
      </div>

      <div class="manifesto-card">
        <span class="manifesto-num">03</span>
        <div class="manifesto-body">
          <h3 class="manifesto-heading">Built for<br>your wall.</h3>
          <p class="manifesto-copy">Collector-grade quality, tufted to last. Hang it, frame it, display it — this is the art your shelves were missing.</p>
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand manifesto",
  "settings": [],
  "presets": [{"name": "Brand manifesto"}]
}
{% endschema %}
