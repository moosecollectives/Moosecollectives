<section class="vault-cta-section">
  <div class="container vault-cta-inner">
    <div class="vault-cta-text">
      <span class="vault-eyebrow">The collection</span>
      <h2 class="vault-heading">Everything<br>in the vault</h2>
    </div>
    <div class="vault-stats">
      <div class="vault-stat">
        <span class="vault-stat-number">500+</span>
        <span class="vault-stat-label">Collectors</span>
      </div>
      <div class="vault-stat">
        <span class="vault-stat-number">4.9★</span>
        <span class="vault-stat-label">Rated</span>
      </div>
      <div class="vault-stat">
        <span class="vault-stat-number">30+</span>
        <span class="vault-stat-label">Drops</span>
      </div>
    </div>
    <a class="button button-primary vault-cta-btn" href="{{ routes.all_products_collection_url }}">
      Shop the vault
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</section>

