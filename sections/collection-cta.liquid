<section class="section proof-strip-section">
  <div class="container">
    <div class="proof-strip">
      <div class="proof-stat">
        <span class="proof-number">500+</span>
        <span class="proof-label">Happy collectors</span>
      </div>
      <div class="proof-divider" aria-hidden="true"></div>
      <div class="proof-stat">
        <span class="proof-number">4.9★</span>
        <span class="proof-label">Average rating</span>
      </div>
      <div class="proof-divider" aria-hidden="true"></div>
      <div class="proof-stat">
        <span class="proof-number">30+</span>
        <span class="proof-label">Active drops</span>
      </div>
      <div class="proof-divider proof-divider-wide" aria-hidden="true"></div>
      <a class="button button-primary proof-cta" href="{{ routes.all_products_collection_url }}">
        Shop the vault
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection CTA",
  "settings": [],
  "presets": [{"name": "Collection CTA"}]
}
{% endschema %}
