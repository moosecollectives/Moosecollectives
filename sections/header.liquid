<header class="header">
  <div class="container header-inner">
    <a class="brand" href="{{ routes.root_url }}">
      {% if settings.logo != blank %}
        {{ settings.logo | image_url: width: 220 | image_tag: alt: shop.name }}
      {% else %}
        {{ shop.name }}
      {% endif %}
    </a>

    <nav class="nav nav-main" aria-label="Main navigation">
      {% for link in linklists[settings.main_menu].links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
      <a href="/pages/faq">FAQ</a>
      <a href="/pages/commissions">Commissions</a>
      <a href="{{ routes.cart_url }}">Cart ({{ cart.item_count }})</a>
    </nav>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
