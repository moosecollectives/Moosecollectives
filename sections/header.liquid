<header class="header">
  <div class="container header-inner">
    <a class="brand" href="{{ routes.root_url }}">
      {% if settings.logo != blank %}
        {{ settings.logo | image_url: width: 160 | image_tag: alt: shop.name }}
      {% else %}
        {{ shop.name }}
      {% endif %}
    </a>

    <nav class="nav nav-desktop" aria-label="Main navigation">
      {% for link in linklists[settings.main_menu].links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
    </nav>

    <div class="nav">
      <a href="{{ routes.cart_url }}" class="cart-link" aria-label="Open cart">
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span class="cart-count" {% if cart.item_count == 0 %}style="display:none"{% endif %}>{{ cart.item_count }}</span>
      </a>
      <a class="button button-secondary nav-desktop" href="{{ routes.account_login_url }}">Account</a>
      <button class="hamburger nav-mobile" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<div class="mobile-nav" id="mobile-nav" aria-hidden="true">
  <div class="mobile-nav-header">
    <span class="mobile-nav-brand">{{ shop.name }}</span>
    <button class="mobile-nav-close" aria-label="Close menu">&#x2715;</button>
  </div>
  <nav class="mobile-nav-links">
    {% for link in linklists[settings.main_menu].links %}
      <a href="{{ link.url }}">{{ link.title }}</a>
    {% endfor %}
    <a href="{{ routes.account_login_url }}">Account</a>
    <a href="{{ routes.cart_url }}">Cart ({{ cart.item_count }})</a>
  </nav>
</div>
<div class="mobile-nav-overlay"></div>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
