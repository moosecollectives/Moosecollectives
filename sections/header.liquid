<header class="header">
  <div class="container header-inner">
    <nav class="nav nav-main" aria-label="Main navigation">
      <details class="nav-dropdown">
        <summary class="nav-toggle">Menu</summary>
        <div class="nav-menu" role="menu">
          {% for link in linklists[settings.main_menu].links %}
            {% unless link.handle == 'contact' %}
              <a href="{{ link.url }}" role="menuitem">{{ link.title }}</a>
            {% endunless %}
          {% endfor %}
          <a href="/pages/commissions" role="menuitem">Commissions</a>
          <a class="cart-link" href="{{ routes.cart_url }}" role="menuitem" data-cart-drawer-trigger>
            <span class="cart-label">Cart</span>
            <span class="cart-count" aria-label="Cart items" {% if cart.item_count == 0 %}hidden{% endif %} data-cart-count>{{ cart.item_count }}</span>
          </a>
        </div>
      </details>
    </nav>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
