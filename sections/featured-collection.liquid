<section class="section">
  <div class="container">
    <div class="section-heading section-heading-center">
      <h2 class="section-title">{{ section.settings.heading }}</h2>
    </div>

    {% assign product_1 = section.settings.product_1 %}
    {% assign product_2 = section.settings.product_2 %}
    {% assign product_3 = section.settings.product_3 %}
    {% assign has_custom = false %}
    {% if product_1 != blank or product_2 != blank or product_3 != blank %}
      {% assign has_custom = true %}
    {% endif %}

    {% if has_custom %}
      <div class="product-grid">
        {% if product_1 != blank %}
          <article class="product-card">
            <a href="{{ product_1.url }}">
              {% if product_1.featured_image %}
                {{ product_1.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product_1.title }}
              {% endif %}
              <h3>{{ product_1.title }}</h3>
              <span class="price">{{ product_1.price | money }}</span>
              <span class="sale-pill">15% off</span>
            </a>
          </article>
        {% endif %}
        {% if product_2 != blank %}
          <article class="product-card">
            <a href="{{ product_2.url }}">
              {% if product_2.featured_image %}
                {{ product_2.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product_2.title }}
              {% endif %}
              <h3>{{ product_2.title }}</h3>
              <span class="price">{{ product_2.price | money }}</span>
              <span class="sale-pill">15% off</span>
            </a>
          </article>
        {% endif %}
        {% if product_3 != blank %}
          <article class="product-card">
            <a href="{{ product_3.url }}">
              {% if product_3.featured_image %}
                {{ product_3.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product_3.title }}
              {% endif %}
              <h3>{{ product_3.title }}</h3>
              <span class="price">{{ product_3.price | money }}</span>
              <span class="sale-pill">15% off</span>
            </a>
          </article>
        {% endif %}
      </div>
    {% elsif section.settings.collection != blank %}
      <div class="product-grid">
        {% for product in section.settings.collection.products limit: 3 %}
          <article class="product-card">
            <a href="{{ product.url }}">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title }}
              {% endif %}
              <h3>{{ product.title }}</h3>
              <span class="price">{{ product.price | money }}</span>
              <span class="sale-pill">15% off</span>
            </a>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <p>Select a collection to feature products here.</p>
    {% endif %}

    {% if section.settings.cta_label != blank %}
      <div class="featured-cta">
        <a class="button button-primary" href="{% if section.settings.cta_link != blank %}{{ section.settings.cta_link }}{% else %}{{ routes.all_products_collection_url }}{% endif %}">{{ section.settings.cta_label }}</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {"type": "text", "id": "heading", "label": "Heading", "default": "Featured picks"},
    {"type": "product", "id": "product_1", "label": "Featured product 1"},
    {"type": "product", "id": "product_2", "label": "Featured product 2"},
    {"type": "product", "id": "product_3", "label": "Featured product 3"},
    {"type": "collection", "id": "collection", "label": "Collection"},
    {"type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop collection"},
    {"type": "url", "id": "cta_link", "label": "CTA link"}
  ],
  "presets": [{"name": "Featured collection"}]
}
{% endschema %}
