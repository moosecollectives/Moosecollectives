<section class="section">
  <div class="container">
    <div class="section-heading">
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      {% if section.settings.cta_label != blank %}
        <a class="button button-secondary" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
      {% endif %}
    </div>

    {% assign featured_products = '' | split: ',' %}
    {% if section.settings.product_1 != blank %}{% assign featured_products = featured_products | push: section.settings.product_1 %}{% endif %}
    {% if section.settings.product_2 != blank %}{% assign featured_products = featured_products | push: section.settings.product_2 %}{% endif %}
    {% if section.settings.product_3 != blank %}{% assign featured_products = featured_products | push: section.settings.product_3 %}{% endif %}

    {% if featured_products.size > 0 %}
      <div class="product-grid">
        {% for product in featured_products %}
          <article class="product-card">
            <a href="{{ product.url }}">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title }}
              {% endif %}
              <h3>{{ product.title }}</h3>
              <span class="price">{{ product.price | money }}</span>
            </a>
          </article>
        {% endfor %}
      </div>
    {% elsif section.settings.collection != blank %}
      <div class="product-grid">
        {% for product in section.settings.collection.products limit: 3 %}
          <article class="product-card">
            <a href="{{ product.url }}">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title }}
              {% endif %}
              <h3>{{ product.title }}</h3>
              <span class="price">{{ product.price | money }}</span>
            </a>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <p>Select a collection to feature products here.</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {"type": "text", "id": "heading", "label": "Heading", "default": "Featured picks"},
    {"type": "product", "id": "product_1", "label": "Featured product 1"},
    {"type": "product", "id": "product_2", "label": "Featured product 2"},
    {"type": "product", "id": "product_3", "label": "Featured product 3"},
    {"type": "collection", "id": "collection", "label": "Collection"},
    {"type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop collection"},
    {"type": "url", "id": "cta_link", "label": "CTA link"}
  ],
  "presets": [{"name": "Featured collection"}]
}
{% endschema %}
