<section class="section featured-rugs-section">
  <div class="container">

    <div class="section-heading featured-rugs-heading">
      <h2 class="section-title">{{ section.settings.heading | default: 'New drops' }}</h2>
      {% if section.settings.cta_label != blank %}
        <a class="section-cta-link" href="{{ section.settings.cta_link | default: routes.all_products_collection_url }}">
          {{ section.settings.cta_label }}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      {% endif %}
    </div>

    {% assign product_1 = section.settings.product_1 %}
    {% assign product_2 = section.settings.product_2 %}
    {% assign product_3 = section.settings.product_3 %}
    {% assign product_4 = section.settings.product_4 %}

    <div class="featured-grid">
      {% if product_1 != blank %}
        {% assign cv_1 = product_1.selected_or_first_available_variant %}
        <article class="collection-carousel-card">
          {% if product_1.available and cv_1.inventory_management == 'shopify' and cv_1.inventory_quantity > 0 and cv_1.inventory_quantity <= 5 %}
            <span class="card-badge card-badge--low" aria-hidden="true">Only {{ cv_1.inventory_quantity }} left</span>
          {% endif %}
          <a href="{{ product_1.url }}">
            {% if product_1.featured_image %}
              {{ product_1.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: product_1.title }}
            {% endif %}
            <h3>{{ product_1.title }}</h3>
            <span class="price price-current">{{ product_1.price | money }}</span>
            {% if product_1.compare_at_price > product_1.price %}
              <span class="price-compare">{{ product_1.compare_at_price | money }}</span>
            {% endif %}
          </a>
          {% if product_1.available %}
            <form class="card-quick-add" method="post" action="/cart/add" data-add-to-cart data-variant-id="{{ cv_1.id }}">
              <input type="hidden" name="id" value="{{ cv_1.id }}">
              <button class="button" type="submit" data-add-to-cart-button>Add to cart</button>
            </form>
          {% endif %}
        </article>
      {% endif %}

      {% if product_2 != blank %}
        {% assign cv_2 = product_2.selected_or_first_available_variant %}
        <article class="collection-carousel-card">
          {% if product_2.available and cv_2.inventory_management == 'shopify' and cv_2.inventory_quantity > 0 and cv_2.inventory_quantity <= 5 %}
            <span class="card-badge card-badge--low" aria-hidden="true">Only {{ cv_2.inventory_quantity }} left</span>
          {% endif %}
          <a href="{{ product_2.url }}">
            {% if product_2.featured_image %}
              {{ product_2.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: product_2.title }}
            {% endif %}
            <h3>{{ product_2.title }}</h3>
            <span class="price price-current">{{ product_2.price | money }}</span>
            {% if product_2.compare_at_price > product_2.price %}
              <span class="price-compare">{{ product_2.compare_at_price | money }}</span>
            {% endif %}
          </a>
          {% if product_2.available %}
            <form class="card-quick-add" method="post" action="/cart/add" data-add-to-cart data-variant-id="{{ cv_2.id }}">
              <input type="hidden" name="id" value="{{ cv_2.id }}">
              <button class="button" type="submit" data-add-to-cart-button>Add to cart</button>
            </form>
          {% endif %}
        </article>
      {% endif %}

      {% if product_3 != blank %}
        {% assign cv_3 = product_3.selected_or_first_available_variant %}
        <article class="collection-carousel-card">
          {% if product_3.available and cv_3.inventory_management == 'shopify' and cv_3.inventory_quantity > 0 and cv_3.inventory_quantity <= 5 %}
            <span class="card-badge card-badge--low" aria-hidden="true">Only {{ cv_3.inventory_quantity }} left</span>
          {% endif %}
          <a href="{{ product_3.url }}">
            {% if product_3.featured_image %}
              {{ product_3.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: product_3.title }}
            {% endif %}
            <h3>{{ product_3.title }}</h3>
            <span class="price price-current">{{ product_3.price | money }}</span>
            {% if product_3.compare_at_price > product_3.price %}
              <span class="price-compare">{{ product_3.compare_at_price | money }}</span>
            {% endif %}
          </a>
          {% if product_3.available %}
            <form class="card-quick-add" method="post" action="/cart/add" data-add-to-cart data-variant-id="{{ cv_3.id }}">
              <input type="hidden" name="id" value="{{ cv_3.id }}">
              <button class="button" type="submit" data-add-to-cart-button>Add to cart</button>
            </form>
          {% endif %}
        </article>
      {% endif %}

      {% if product_4 != blank %}
        {% assign cv_4 = product_4.selected_or_first_available_variant %}
        <article class="collection-carousel-card">
          {% if product_4.available and cv_4.inventory_management == 'shopify' and cv_4.inventory_quantity > 0 and cv_4.inventory_quantity <= 5 %}
            <span class="card-badge card-badge--low" aria-hidden="true">Only {{ cv_4.inventory_quantity }} left</span>
          {% endif %}
          <a href="{{ product_4.url }}">
            {% if product_4.featured_image %}
              {{ product_4.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: product_4.title }}
            {% endif %}
            <h3>{{ product_4.title }}</h3>
            <span class="price price-current">{{ product_4.price | money }}</span>
            {% if product_4.compare_at_price > product_4.price %}
              <span class="price-compare">{{ product_4.compare_at_price | money }}</span>
            {% endif %}
          </a>
          {% if product_4.available %}
            <form class="card-quick-add" method="post" action="/cart/add" data-add-to-cart data-variant-id="{{ cv_4.id }}">
              <input type="hidden" name="id" value="{{ cv_4.id }}">
              <button class="button" type="submit" data-add-to-cart-button>Add to cart</button>
            </form>
          {% endif %}
        </article>
      {% endif %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {"type": "text", "id": "heading", "label": "Heading", "default": "New drops"},
    {"type": "product", "id": "product_1", "label": "Featured product 1"},
    {"type": "product", "id": "product_2", "label": "Featured product 2"},
    {"type": "product", "id": "product_3", "label": "Featured product 3"},
    {"type": "product", "id": "product_4", "label": "Featured product 4"},
    {"type": "collection", "id": "collection", "label": "Collection"},
    {"type": "text", "id": "cta_label", "label": "CTA label", "default": "See all drops"},
    {"type": "url", "id": "cta_link", "label": "CTA link"}
  ],
  "presets": [{"name": "Featured collection"}]
}
{% endschema %}
