<section class="section">
  <div class="container">
    <div class="section-heading">
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      {% if section.settings.cta_label != blank %}
        <a class="button button-secondary" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
      {% endif %}
    </div>

    {% if section.settings.collection != blank %}
      <div class="product-grid">
        {% for product in section.settings.collection.products limit: 6 %}
          <article class="product-card">
            <a href="{{ product.url }}">
              <div class="product-card-img">
                {% if product.featured_image %}
                  {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title, width: product.featured_image.width, height: product.featured_image.height }}
                {% endif %}
                {% unless product.available %}
                  <span class="card-badge badge-out">Sold out</span>
                {% else %}
                  {% assign cv = product.selected_or_first_available_variant %}
                  {% if cv.inventory_management == 'shopify' and cv.inventory_quantity > 0 and cv.inventory_quantity <= 5 %}
                    <span class="card-badge badge-low">Only {{ cv.inventory_quantity }} left</span>
                  {% endif %}
                {% endunless %}
              </div>
              <h3>{{ product.title }}</h3>
              <span class="price">{{ product.price | money }}</span>
            </a>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <p>Select a collection to feature products here.</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {"type": "text", "id": "heading", "label": "Heading", "default": "Featured picks"},
    {"type": "collection", "id": "collection", "label": "Collection"},
    {"type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop collection"},
    {"type": "url", "id": "cta_link", "label": "CTA link"}
  ],
  "presets": [{"name": "Featured collection"}]
}
{% endschema %}
