<section class="section ugc-section">
  <div class="container">
    <div class="ugc-heading">
      <span class="hero-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="section-title">{{ section.settings.heading }}</h2>
    </div>

    {% if section.blocks.size > 0 %}
      <div class="ugc-grid">
        {% for block in section.blocks %}
          <div class="ugc-item" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              <div class="ugc-img-wrap">
                {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.caption, width: block.settings.image.width, height: block.settings.image.height }}
              </div>
            {% else %}
              <div class="ugc-img-wrap ugc-placeholder"></div>
            {% endif %}
            {% if block.settings.caption != blank %}
              <p class="ugc-caption">"{{ block.settings.caption }}"</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% else %}
      <p class="ugc-empty">Add customer photos in the theme editor to fill this section.</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "UGC gallery",
  "max_blocks": 8,
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Collectors love it"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Real rugs, real rooms"}
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        {"type": "image_picker", "id": "image", "label": "Customer photo"},
        {"type": "text", "id": "caption", "label": "Customer quote or caption"}
      ]
    }
  ],
  "presets": [{"name": "UGC gallery"}]
}
{% endschema %}
