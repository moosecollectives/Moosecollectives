<section class="section">
  <div class="container">
    <h1 class="section-title">Your cart</h1>
    {% if cart.item_count == 0 %}
      <p>Your cart is empty.</p>
      <a class="button button-primary" href="{{ routes.collections_url }}">Continue shopping</a>
    {% else %}
      <form action="{{ routes.cart_url }}" method="post">
        <div class="product-grid">
          {% for item in cart.items %}
            <article class="product-card">
              <div>
                {% if item.image %}
                  {{ item.image | image_url: width: 400 | image_tag: loading: 'lazy', alt: item.product.title }}
                {% endif %}
              </div>
              <div>
                <h3>{{ item.product.title }}</h3>
                <p>{{ item.final_price | money }}</p>
                <input type="number" name="updates[]" value="{{ item.quantity }}" min="0">
              </div>
            </article>
          {% endfor %}
        </div>
        <button class="button button-primary" type="submit" name="checkout">Checkout</button>
      </form>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main cart",
  "settings": []
}
{% endschema %}
