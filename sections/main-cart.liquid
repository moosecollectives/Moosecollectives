<section class="section cart-section">
  <div class="container">
    <h1 class="section-title">Your cart</h1>
    {% if cart.item_count == 0 %}
      <p>Your cart is empty.</p>
      <a class="button button-primary" href="{{ routes.all_products_collection_url }}">Continue shopping</a>
    {% else %}
      {% assign upsell_product = all_products['adhesive-wall-strip'] %}
      {% assign has_adhesive = false %}
      {% for item in cart.items %}
        {% if item.product.handle == 'adhesive-wall-strip' %}
          {% assign has_adhesive = true %}
        {% endif %}
      {% endfor %}
      {% if upsell_product != blank and has_adhesive == false %}
        <div class="cart-upsell">
          <div>
            <span class="upsell-eyebrow">Recommended add-on</span>
            <h3 class="upsell-title">Add adhesive strips to your order</h3>
            <p class="upsell-subtitle">Keep your rug secure with our mounting strips.</p>
          </div>
          <form class="cart-upsell-form" method="post" action="/cart/add" data-cart-upsell>
            <input type="hidden" name="id" value="{{ upsell_product.selected_or_first_available_variant.id }}">
            <button class="button button-secondary" type="submit">Add to cart</button>
          </form>
        </div>
      {% endif %}
      <form action="{{ routes.cart_url }}" method="post" data-cart-form>
        <div class="cart-carousel" data-cart-carousel>
          <div class="cart-track">
            {% for item in cart.items %}
              <article class="cart-card">
                <a class="cart-media" href="{{ item.url }}" aria-label="View {{ item.product.title }}">
                  {% if item.image %}
                    {{ item.image | image_url: width: 500 | image_tag: loading: 'lazy', alt: item.product.title }}
                  {% endif %}
                </a>
                <div class="cart-meta">
                  <h3>{{ item.product.title }}</h3>
                  <div class="cart-meta-row">
                    <p class="price cart-price" aria-label="Line item price">
                      <span class="cart-price-total">{{ item.final_line_price | money }}</span>
                      <span class="cart-price-breakdown">{{ item.final_price | money }} x {{ item.quantity }}</span>
                    </p>
                    <div class="cart-quantity" data-cart-qty-wrap>
                      <div class="cart-quantity-pill" role="group" aria-label="Quantity controls for {{ item.product.title }}">
                        <button class="cart-quantity-btn" type="button" data-cart-qty-btn="minus" aria-label="Decrease quantity">-</button>
                        <input
                          id="Quantity-{{ item.key }}"
                          class="cart-quantity-input"
                          type="number"
                          name="updates[{{ item.key }}]"
                          value="{{ item.quantity }}"
                          min="0"
                          inputmode="numeric"
                          aria-label="Quantity for {{ item.product.title }}"
                          data-cart-qty
                          data-cart-title="{{ item.product.title | escape }}"
                        >
                        <button class="cart-quantity-btn" type="button" data-cart-qty-btn="plus" aria-label="Increase quantity">+</button>
                      </div>
                    </div>
                  </div>
                  <button class="cart-remove-tab" type="button" data-cart-remove-key="{{ item.key }}" aria-label="Remove {{ item.product.title }} from cart">
                    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                      <path d="M9 3h6l1 2h4v2H4V5h4l1-2zm1 6h2v9h-2V9zm4 0h2v9h-2V9zM7 9h2v9H7V9z"/>
                    </svg>
                  </button>
                  <div class="cart-actions">
                  </div>
                </div>
              </article>
            {% endfor %}
          </div>
        </div>
        <div class="cart-footer">
          <p class="cart-total">Total: {{ cart.total_price | money }}</p>
          <button class="button button-secondary" type="submit" name="update">Update cart</button>
          <button class="button button-primary" type="submit" name="checkout">Checkout</button>
        </div>
      </form>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main cart",
  "settings": []
}
{% endschema %}
