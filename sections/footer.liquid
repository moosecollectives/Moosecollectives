<footer class="footer">
  <div class="container footer-grid">
    <div>
      <h4>{{ shop.name }}</h4>
      <p>{{ settings.footer_text }}</p>
    </div>
    <div>
      <h4>Explore</h4>
      <p><a href="{{ routes.collections_url }}">Shop all</a></p>
      <p><a href="{{ routes.search_url }}">Search</a></p>
      <p><a href="{{ routes.cart_url }}">Cart</a></p>
    </div>
    <div>
      <h4>Support</h4>
      <p>{{ settings.contact_email }}</p>
      <p>{{ settings.contact_phone }}</p>
    </div>
    <div class="footer-newsletter">
      <h4>Stay in the loop</h4>
      <p>New drops, exclusive offers, and more — straight to your inbox.</p>
      <form class="newsletter-form" action="/contact#contact_form" method="post">
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="✓">
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter-row">
          <label for="footer-email" class="input-label">Email address</label>
          <input id="footer-email" class="email-input" type="email" name="contact[email]" placeholder="your@email.com" required autocomplete="email">
          <button class="button button-primary" type="submit">Subscribe</button>
        </div>
      </form>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
