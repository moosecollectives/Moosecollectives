<footer class="footer">
  <div class="container footer-grid">
    <div>
      <h4>{{ shop.name }}</h4>
      <p>{{ settings.footer_text }}</p>
    </div>
    <div>
      <h4>Explore</h4>
      {% for link in linklists[settings.main_menu].links %}
        <p><a href="{{ link.url }}">{{ link.title }}</a></p>
      {% endfor %}
      <p><a href="/pages/faq">FAQ</a></p>
      <p><a href="/pages/commissions">Commissions</a></p>
      <p><a href="{{ routes.cart_url }}">Cart</a></p>
    </div>
    <div>
      <h4>Support</h4>
      <p>{{ settings.contact_email }}</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
