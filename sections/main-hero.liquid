<section class="section hero">
  <div class="container hero-grid">
    <div class="hero-panel">
      <span class="hero-eyebrow">{{ section.settings.eyebrow }}</span>
      <h1 class="hero-title">{{ section.settings.heading }}</h1>
      <p class="hero-subtitle">{{ section.settings.subheading }}</p>
      <div class="hero-actions">
        {% if section.settings.primary_label != blank %}
          <a class="button button-primary" href="{{ section.settings.primary_link }}">
            {{ section.settings.primary_label }}
          </a>
        {% endif %}
        {% if section.settings.secondary_label != blank %}
          <a class="button button-secondary" href="{% if section.settings.secondary_link != blank %}{{ section.settings.secondary_link }}{% else %}/pages/commissions{% endif %}">
            {{ section.settings.secondary_label }}
          </a>
        {% endif %}
      </div>
      <div class="hero-stats">
        <div>
          <span class="hero-stat-number">Limited run</span>
          <span class="hero-stat-label">Collector focus</span>
        </div>
        <div>
          <span class="hero-stat-number">35+</span>
          <span class="hero-stat-label">New arrivals</span>
        </div>
        <div>
          <span class="hero-stat-number">4.9</span>
          <span class="hero-stat-label">Collector rated</span>
        </div>
      </div>
    </div>

    <div class="hero-media-frame">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1600 | image_tag: loading: 'lazy', alt: section.settings.heading }}
      {% else %}
        <div class="hero-placeholder"></div>
      {% endif %}
      <div class="hero-ticker">Pop icons. Vintage drops. Limited glow.</div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main hero",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Drop radar"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Culture collectibles, reframed"},
    {"type": "textarea", "id": "subheading", "label": "Subheading", "default": "A rotating vault of pop culture pieces with bold energy and collector-grade finishes."},
    {"type": "text", "id": "primary_label", "label": "Primary button label", "default": "Shop the vault"},
    {"type": "url", "id": "primary_link", "label": "Primary button link"},
    {"type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "See commissions"},
    {"type": "url", "id": "secondary_link", "label": "Secondary button link"},
    {"type": "image_picker", "id": "image", "label": "Hero media"}
  ]
}
{% endschema %}
