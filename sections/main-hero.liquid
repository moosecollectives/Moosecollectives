<section class="hero">
  <div class="hero-media">
    {% if section.settings.video != blank %}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
    {% elsif section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'eager', alt: section.settings.heading }}
    {% else %}
      <div class="hero-placeholder"></div>
    {% endif %}
  </div>
  <div class="container hero-content">
    <div class="hero-panel">
      <span class="hero-eyebrow">{{ section.settings.eyebrow | default: 'Collector culture' }}</span>
      <h1 class="hero-title">
        {% if section.settings.heading != blank %}
          {{ section.settings.heading }}
        {% else %}
          Culture<br>Collectibles,<br>Reframed
        {% endif %}
      </h1>
      <p class="hero-subtitle">
        {% if section.settings.subheading != blank %}
          {{ section.settings.subheading }}
        {% else %}
          Limited run pop culture pieces built for collectors. Hang what you love.
        {% endif %}
      </p>
      <div class="hero-actions">
        <a class="hero-btn-primary" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">
          {{ section.settings.primary_label | default: 'Shop the vault' }}
        </a>
        {% if section.settings.secondary_label != blank %}
          <a class="hero-btn-ghost" href="{{ section.settings.secondary_link | default: '/pages/commissions' }}">
            {{ section.settings.secondary_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main hero",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Collector culture"},
    {"type": "text", "id": "heading", "label": "Heading"},
    {"type": "textarea", "id": "subheading", "label": "Subheading"},
    {"type": "text", "id": "primary_label", "label": "Primary button label", "default": "Shop the vault"},
    {"type": "url", "id": "primary_link", "label": "Primary button link"},
    {"type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "Custom commissions"},
    {"type": "url", "id": "secondary_link", "label": "Secondary button link"},
    {"type": "image_picker", "id": "image", "label": "Hero image"},
    {"type": "video", "id": "video", "label": "Hero video"}
  ]
}
{% endschema %}
