{% doc %}
  @prompt
    text prompt for aa commissions being closed 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-commissions-closed-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-commissions-closed__container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-commissions-closed__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto {{ block.settings.icon_spacing }}px;
    color: {{ block.settings.icon_color }};
  }

  .ai-commissions-closed__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-commissions-closed__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-commissions-closed__message-{{ ai_gen_id }} {
    color: {{ block.settings.message_color }};
    font-size: {{ block.settings.message_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  .ai-commissions-closed__message-{{ ai_gen_id }} p {
    margin: 0 0 12px 0;
  }

  .ai-commissions-closed__message-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-commissions-closed__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.85);
    }

    .ai-commissions-closed__message-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.message_size }}px * 0.9);
    }

    .ai-commissions-closed__icon-{{ ai_gen_id }} {
      width: calc({{ block.settings.icon_size }}px * 0.8);
      height: calc({{ block.settings.icon_size }}px * 0.8);
    }
  }
{% endstyle %}

<commissions-closed-{{ ai_gen_id }}
  class="ai-commissions-closed-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-commissions-closed__container-{{ ai_gen_id }}">
    {% if block.settings.show_icon %}
      <div class="ai-commissions-closed__icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="15" y1="9" x2="9" y2="15"></line>
          <line x1="9" y1="9" x2="15" y2="15"></line>
        </svg>
      </div>
    {% endif %}

    {% if block.settings.heading != blank %}
      <h2 class="ai-commissions-closed__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.message != blank %}
      <div class="ai-commissions-closed__message-{{ ai_gen_id }}">
        {{ block.settings.message }}
      </div>
    {% endif %}
  </div>
</commissions-closed-{{ ai_gen_id }}>

<script>
  (function() {
    class CommissionsClosed{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('commissions-closed-{{ ai_gen_id }}', CommissionsClosed{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Commissions closed",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Commissions Currently Closed"
    },
    {
      "type": "richtext",
      "id": "message",
      "label": "Message",
      "default": "<p>Thank you for your interest in commissioning custom work. We are not accepting new commission requests at this time.</p><p>Please check back later or follow us on social media for updates on when commissions will reopen.</p>"
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show icon",
      "default": true
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "icon_spacing",
      "label": "Icon spacing",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#D82C0D"
    },
    {
      "type": "header",
      "content": "Heading style"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Spacing below",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "700"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Message style"
    },
    {
      "type": "range",
      "id": "message_size",
      "label": "Size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "message_color",
      "label": "Color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFF4E6"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#FFB84D"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Commissions closed"
    }
  ]
}
{% endschema %}
